Metodo che permettere ricercare un cammino che permetta di massimizzare la somma dei
pesi degli archi tra un nodo sorgente ed un nodo di destinazione, rispettando il vincolo
del numero massimo di archi che si possono percorrere. (FlightDelays)
####################################################################################
def getPesoArco(self, u, v):
   """Restituisce il peso dell'arco tra u e v."""
   return self._grafo[u][v]["weight"]


def score(self, parziale):
   """ Calcola il punteggio di un cammino parziale.
       Il punteggio è dato dalla somma dei pesi degli archi
       attraversati dal percorso. """
   score = 0
   for i in range(len(parziale) - 1):
       u = parziale[i]
       v = parziale[i + 1]
       score += self.getPesoArco(u, v)
   return score+


def getPath(self, a1, a2, t):
   """ Cerca il miglior percorso che massimizza la somma dei pesi
   degli archi attraversati, da a1 ad a2 usando al massimo t archi.
       Parametri:
       - a1: artista di partenza
       - a2: artista di destinazione
       - t: numero massimo di archi percorribili
       Ritorna:
       - self._bestPath: percorso migliore trovato
       - self._costoCammino: peso totale del percorso migliore"""
   # Controllo che i nodi esistano nel grafo
   if a1 not in self._grafo.nodes:
       return [], -1
   if a2 not in self._grafo.nodes:
       return [], -1
# Controllo che il numero massimo di archi sia valido
   if t <= 0:
       return [], -1
# Inizializzo le variabili per la ricorsione
   parziale = [a1]
   self._bestPath = []
   self._costoCammino = -1
   self._destinazione = a2
   self._maxArchi = t


#Controllo che i nodi inseriti  non siano uguali
   if a1 == a2:
       self._bestPath = [a1]
       self._costoCammino = 0
       return self._bestPath, self._costoCammino


#Controllo che se i nodi sono diversi il numero di tratte sia uguale a 0
   if t == 0:
       return [], -1


#Inizio il meccanismo di ricorsione / backtracking per verificare se posso aggiungere gli archi
   # Esploro solo i successori del nodo sorgente,
   # cioè i nodi raggiungibili tramite archi uscenti da a1.
   for v in self._grafo.successors(a1):
       if v not in parziale:
           parziale.append(v)
           # Avvio la ricorsione dal cammino [a1, v].
           self.ricorsione(parziale)
           # Backtracking.
           parziale.pop()
   return self._bestPath, self._costoCammino




def ricorsione(self, parziale):
   """Metodo ricorsivo per cercare il percorso da a1 ad a2
   che massimizza la somma dei pesi degli archi attraversati,
   usando al massimo self._maxArchi archi.
   Il grafo è orientato, quindi vengono esplorati solo i successori
   del nodo corrente.
   """


   # Recupero l'ultimo nodo inserito nel percorso parziale
   nodo_corrente = parziale[-1]


   # Calcolo quanti archi sono stati già usati.
   # Se il percorso contiene n nodi, allora contiene n-1 archi.
   archi_usati = len(parziale) - 1


   # Caso base 1:
   # se il nodo corrente è la destinazione, ho trovato un percorso valido.
   if nodo_corrente == self._destinazione:
       punteggio_attuale = self.score(parziale)


       # Se il percorso trovato è migliore del migliore salvato finora,
       # aggiorno bestPath e costoCammino.
       if punteggio_attuale > self._costoCammino:
           self._bestPath = copy.deepcopy(parziale)
           self._costoCammino = punteggio_attuale
       # Mi fermo: non proseguo oltre la destinazione.
       return


   # Caso base 2:
   # se ho già raggiunto il numero massimo di archi disponibili,
   # non posso più continuare la ricerca.
   if archi_usati == self._maxArchi:
       return


   # Esploro i successori del nodo corrente.
   # In un grafo orientato si possono percorrere solo gli archi uscenti.
   for v in self._grafo.successors(nodo_corrente):
       # Evito cicli: non inserisco nel percorso un nodo già visitato.
       if v not in parziale:
           # Aggiungo il successore al percorso parziale.
           parziale.append(v)


           # Richiamo ricorsivamente la funzione sul nuovo percorso.
           self.ricorsione(parziale)


           # Backtracking:
           # rimuovo l'ultimo nodo per provare altri successori.
           parziale.pop()


