pesi degli archi tra un nodo sorgente ed un nodo di destinazione
####################################################################################
def getPesoArco(self, u, v):
   """
   Restituisce il peso dell'arco orientato u -> v.
   """
   return self._grafo[u][v]["weight"]


def score(self, parziale):
   """
   Calcola il costo totale del cammino parziale.
   Il costo è la somma dei pesi degli archi attraversati.
   """
   costo = 0
   for i in range(len(parziale) - 1):
       u = parziale[i]
       v = parziale[i + 1]
       costo += self.getPesoArco(u, v)


   return costo


def getPath(self, a1, a2):
   """
   Cerca il cammino da a1 ad a2 che minimizza la somma
   dei pesi degli archi attraversati.
   Ritorna:
   - bestPath: cammino migliore trovato
   - costoCammino: costo minimo del cammino
   """


   # Controllo che il nodo sorgente esista nel grafo
   if a1 not in self._grafo.nodes:
       return [], -1
   # Controllo che il nodo destinazione esista nel grafo
   if a2 not in self._grafo.nodes:
       return [], -1
   # Inizializzo le variabili della ricerca
   parziale = [a1]
   self._bestPath = []
   self._costoCammino = math.inf
   self._destinazione = a2


   # Caso particolare: sorgente e destinazione coincidono
   if a1 == a2:
       return [a1], 0
   # Esploro i successori del nodo sorgente.
   # In un grafo orientato considero solo gli archi uscenti da a1.
   for v in self._grafo.successors(a1):
       if v not in parziale:
           parziale.append(v)
           # Avvio la ricorsione dal cammino [a1, v]
           self.ricorsione(parziale)
           # Backtracking
           parziale.pop()


   return self._bestPath, self._costoCammino


def ricorsione(self, parziale):
   """
   Metodo ricorsivo per cercare il cammino da sorgente a destinazione
   con costo totale minimo.
   Il grafo è orientato, quindi vengono esplorati solo i successori
   del nodo corrente.
   """


   # Recupero l'ultimo nodo inserito nel cammino parziale
   nodo_corrente = parziale[-1]


   # Calcolo il costo attuale del cammino parziale
   costo_attuale = self.score(parziale)


   # Potatura:
   # se il costo attuale è già maggiore o uguale al miglior costo trovato,
   # non ha senso continuare questo ramo.
   if costo_attuale >= self._costoCammino:
       return


   # Caso base:
   # se sono arrivato alla destinazione, valuto il cammino trovato.
   if nodo_corrente == self._destinazione:
       if costo_attuale < self._costoCammino:
           self._bestPath = copy.deepcopy(parziale)
           self._costoCammino = costo_attuale


       return


   # Esploro solo i successori del nodo corrente
   for v in self._grafo.successors(nodo_corrente):
       # Evito cicli nel cammino
       if v not in parziale:
           parziale.append(v)
           self.ricorsione(parziale)
           parziale.pop()


